# ─────────────────────────────────────────────────────────────────────────────
# mt5-ai-trader — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── MT5 API ──────────────────────────────────────────────────────────────────
# URL of the MT5 REST server (default: local server on port 8000)
MT5_API_URL=http://localhost:8000

# Optional API key if your MT5 server requires authentication (leave blank if not)
MT5_API_KEY=

# ── Trading Symbol ────────────────────────────────────────────────────────────
# Symbol to trade. Must match exactly what your broker shows in MT5.
# Common: XAUUSD, GOLD, GOLD.i#, EURUSD, BTCUSD
SYMBOL=XAUUSD

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: claude | openai | gemini
AI_PROVIDER=claude

# Your AI API key (get from: claude.ai / platform.openai.com / aistudio.google.com)
AI_API_KEY=your_api_key_here

# AI Model to use (optional — defaults shown below)
# Claude:  claude-opus-4-6  |  claude-sonnet-4-6  |  claude-haiku-4-5-20251001
# OpenAI:  gpt-4o  |  gpt-4-turbo
# Gemini:  gemini-1.5-pro  |  gemini-1.5-flash
AI_MODEL=claude-sonnet-4-6

# ── Database (optional — for trade logging + AI self-improvement) ─────────────
# Leave blank to disable database logging (trades logged to CSV instead)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://trader:password@localhost:5432/mt5trader

# ── Scalping Parameters ───────────────────────────────────────────────────────
SL_POINTS=1.0           # Stop loss in points
TP_POINTS=5.0           # Take profit in points
VOLUME=0.01             # Lot size (0.01=micro, 0.1=mini, 1.0=standard)

# ── Entry Signal Tuning ───────────────────────────────────────────────────────
POLL_MS=200             # How often to check price (milliseconds)
MOMENTUM_WINDOW=8       # Number of ticks to analyze
MIN_DIRECTION_PCT=0.75  # 75% of ticks must go same direction for a signal
MIN_MOVE_POINTS=0.5     # Minimum price move to qualify
MAX_SPREAD_POINTS=0.8   # Skip trade if spread is wider than this

# ── Risk Management ───────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT=-50.0  # Stop trading if daily loss exceeds this (in account currency)
MAX_DAILY_TRADES=30     # Stop trading after this many trades per day
MAX_POSITIONS=1         # Maximum open trades at once
POSITION_TIMEOUT_SEC=120 # Force-close trade after N seconds (0 = disabled)

# ── Paper Trading ─────────────────────────────────────────────────────────────
# Set to true to simulate without placing real orders (for testing)
PAPER=false
