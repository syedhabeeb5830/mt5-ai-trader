# ─────────────────────────────────────────────────────────────────────────────
# mt5-ai-trader — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── MT5 API ──────────────────────────────────────────────────────────────────
# URL of the MT5 REST server (default: local server on port 8000)
MT5_API_URL=http://localhost:8000

# Optional API key if your MT5 server requires authentication (leave blank if not)
MT5_API_KEY=

# ── Trading Symbol ────────────────────────────────────────────────────────────
# Symbol to trade. Must match exactly what your broker shows in MT5.
# Common: XAUUSD, GOLD, GOLD.i#, EURUSD, BTCUSD
SYMBOL=XAUUSD

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: claude | openai | gemini
AI_PROVIDER=claude

# Your AI API key (get from: claude.ai / platform.openai.com / aistudio.google.com)
AI_API_KEY=your_api_key_here

# AI Model to use (optional — defaults shown below)
# Claude:      claude-opus-4-6  |  claude-sonnet-4-6  |  claude-haiku-4-5-20251001
# OpenAI:      gpt-4o  |  gpt-4-turbo
# Gemini:      gemini-1.5-pro  |  gemini-1.5-flash
# OpenRouter:  anthropic/claude-sonnet-4-6  |  openai/gpt-4o  |  google/gemini-pro
AI_MODEL=claude-sonnet-4-6

# Optional: Override API base URL (for OpenRouter or any OpenAI-compatible endpoint)
# OpenRouter: https://openrouter.ai/api/v1
# Leave blank for direct API access
AI_BASE_URL=

# ── Database (optional — for trade logging + AI self-improvement) ─────────────
# Leave blank to disable database logging (trades logged to CSV instead)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://trader:password@localhost:5432/mt5trader

# ── Scalping Parameters ───────────────────────────────────────────────────────
SL_POINTS=1.0           # Stop loss in points
TP_POINTS=5.0           # Take profit in points
VOLUME=0.01             # Lot size (0.01=micro, 0.1=mini, 1.0=standard)

# ── Entry Signal Tuning ───────────────────────────────────────────────────────
POLL_MS=200             # How often to check price (milliseconds)
MOMENTUM_WINDOW=8       # Number of ticks to analyze
MIN_DIRECTION_PCT=0.75  # 75% of ticks must go same direction for a signal
MIN_MOVE_POINTS=0.5     # Minimum price move to qualify
MAX_SPREAD_POINTS=0.8   # Skip trade if spread is wider than this

# ── Risk Management ───────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT=-50.0  # Stop trading if daily loss exceeds this (in account currency)
MAX_DAILY_TRADES=30     # Stop trading after this many trades per day
MAX_POSITIONS=1         # Maximum open trades at once
POSITION_TIMEOUT_SEC=120 # Force-close trade after N seconds (0 = disabled)

# ── ML Platform ───────────────────────────────────────────────────────────────
# Label profile: scalp | intraday | swing | momentum
ML_LABEL_PROFILE=momentum

# ATR multipliers for dynamic SL/TP (instrument-agnostic)
ML_ATR_SL_MULT=0.5       # SL = ATR(14) × this value
ML_RR_RATIO=2.0          # TP = SL × this value (risk/reward)

# File paths (relative to project root)
ML_MODELS_DIR=models
ML_DATA_DB=ml/data/market.db

# Retraining schedule: weekly | biweekly | monthly
ML_RETRAIN_SCHEDULE=weekly

# Minimum samples before a model is trained
ML_MIN_SAMPLES=500

# Universal model: train one model across all instruments (true | false)
ML_UNIVERSAL_MODEL=false

# ── Per-Instrument ML Overrides ──────────────────────────────────────────────
# Probability thresholds (BUY signal fires when P >= buy threshold)
ML_BUY_THRESH_XAUUSD=0.72
ML_SELL_THRESH_XAUUSD=0.28
ML_BUY_THRESH_EURUSD=0.65
ML_SELL_THRESH_EURUSD=0.35
ML_BUY_THRESH_GBPUSD=0.68
ML_SELL_THRESH_GBPUSD=0.32

# Model types per instrument: xgboost | lightgbm | random_forest
ML_MODEL_TYPE_XAUUSD=xgboost
ML_MODEL_TYPE_EURUSD=lightgbm
ML_MODEL_TYPE_GBPUSD=lightgbm

# Active trading hours (UTC) per instrument: "start-end" 24h format
ML_HOURS_XAUUSD=14-18
ML_HOURS_EURUSD=7-17
ML_HOURS_GBPUSD=7-17

# ── Paper Trading ─────────────────────────────────────────────────────────────
# Set to true to simulate without placing real orders (for testing)
PAPER=false
